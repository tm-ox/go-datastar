templ CartBadge() {
	<div
		class="relative ml-2 group cursor-pointer"
		data-on:click="$drawerOpen = true; @get('/cart/drawer')"
	>
		@IconCart(IconProps{Class: "mb-2 text-border hover:text-accent"})
		<span
			data-show="$cartTotal > 0"
			data-text="$cartTotal"
			class="absolute -top-2 -right-2 text-xs bg-accent/80 text-surface font-bold rounded-full w-4 h-4 flex items-center justify-center leading-none pointer-events-none"
		></span>
	</div>
}
