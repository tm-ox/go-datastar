
package views

import (
	"github.com/tm-ox/go-datastar/internal/store/product"
	"github.com/tm-ox/go-datastar/views/modules"
)

templ ShopGrid(products []product.Product) {
	<div id="shop-grid" class="grid grid-cols-3 grid-rows-[auto_auto_auto_auto_auto_auto] gap-x-4">
		for _, p := range products {
			@modules.CardProduct(&p)
		}
	</div>
}
